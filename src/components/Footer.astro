---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-slogan">思考，書寫，懷疑，然後重新開始。</p>
    <p class="footer-copy">&copy; {year} WAHSUN</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    padding: 2rem 0 2.5rem;
    text-align: center;
    position: relative;
  }
  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-slogan {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    font-weight: 500;
    opacity: 0.8;
  }
  .footer-copy {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }
</style>
