---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-copy">&copy; 2026</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    padding: 2rem 0 2rem;
    text-align: center;
    position: relative;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .footer-copy {
    font-family: var(--font-heading);
    font-size: 0.625rem;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }
</style>
