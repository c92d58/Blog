---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-copy">&copy; {year} 聽雨</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-3xl);
    padding: var(--space-xl) 0 var(--space-lg);
    position: relative;
    text-align: center;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 25%;
    right: 25%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-items: center;
  }

  .footer-copy {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    letter-spacing: 0.02em;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-tertiary);
    font-style: italic;
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .footer { margin-top: var(--space-2xl); padding: var(--space-lg) 0; }
  }
</style>
