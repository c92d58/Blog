---
import "../styles/global.css";

interface Props { title: string; description?: string; ogType?: "website" | "article"; ogImage?: string }
const {
  title,
  description = "思考、書寫、懷疑，然後重新開始！",
  ogType = "website",
  ogImage = "/hero-bg.jpg"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageAbs = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" id="theme-meta" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23111'/%3E%3Ctext x='16' y='22' text-anchor='middle' font-size='18' font-family='sans-serif' font-weight='700' fill='%23fff'%3EW%3C/text%3E%3C/svg%3E" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="WAHSUN ｜ Blog" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="WAHSUN ｜ Blog" />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="logo">WAHSUN ｜ Blog</a>
        <button class="tt" id="tt" aria-label="切換主題">
          <svg class="si" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="mo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </nav>
    <slot />
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          <span>在喧囂中，留一點安靜</span>
        </div>
        <p class="footer-copy">&copy; 2026 WAHSUN</p>
      </div>
    </footer>
    <script>
      const tt=document.getElementById('tt'),h=document.documentElement,tm=document.getElementById('theme-meta');
      const apply=()=>{
        const d=h.classList.contains('dark');
        if(tm)tm.content=d?'#0a0a0a':'#ffffff';
      };
      localStorage.getItem('theme')==='dark'?h.classList.add('dark'):h.classList.remove('dark');
      apply();
      tt.addEventListener('click',()=>{h.classList.toggle('dark');localStorage.setItem('theme',h.classList.contains('dark')?'dark':'light');apply()});

      document.querySelectorAll('.post-item').forEach((el,i)=>{
        el.style.transitionDelay=i*50+'ms';
        new IntersectionObserver(([e])=>{if(e.isIntersecting){el.classList.add('reveal');e.target._o?.disconnect()}},{threshold:.15,rootMargin:'0px 0px -30px 0px'}).observe(el)
      });

      window.addEventListener('scroll',()=>{const h=document.querySelector('.hero');if(h)h.style.setProperty('--scroll',window.scrollY/4+'px')},{passive:true});
    </script>
  </body>
</html>
