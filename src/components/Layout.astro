---
import "../styles/global.css";

interface Props { title: string; description?: string; ogType?: "website" | "article"; ogImage?: string }
const {
  title,
  description = "思考、書寫、懷疑，然後重新開始！",
  ogType = "website",
  ogImage = "/hero-bg.jpg"
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageAbs = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="zh-TW" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect x='3' y='3' width='26' height='26' rx='4' fill='%2300ff88'/%3E%3Ccircle cx='16' cy='17' r='5' fill='%230a0a0f' opacity='.85'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;800&family=Inter:wght@400;600&display=swap" rel="stylesheet" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="WAHSUN ｜ Blog" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="WAHSUN ｜ Blog" />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="logo-wrap">
          <span class="logo-mark">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="20" height="20" rx="3" fill="var(--g)" opacity=".15"/>
              <path d="M7 17L12 7L17 17H7Z" fill="var(--g)" opacity=".4"/>
              <circle cx="12" cy="13" r="2.5" fill="var(--g)"/>
            </svg>
          </span>
          <span class="logo-text">WAHSUN_blog</span>
        </a>
      </div>
    </nav>
    <slot />
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-icon">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          <span>在喧囂中，留一點安靜</span>
        </div>
        <p class="footer-copy">&copy; 2026 WAHSUN</p>
      </div>
    </footer>
    <script>
      // Stagger reveal for post items
      document.querySelectorAll('.post-item').forEach((el,i)=>{
        el.style.transitionDelay=i*50+'ms';
        new IntersectionObserver(([e])=>{if(e.isIntersecting){el.classList.add('reveal');e.target._o?.disconnect()}},{threshold:.15,rootMargin:'0px 0px -30px 0px'}).observe(el)
      });

      // Hero scroll parallax
      window.addEventListener('scroll',()=>{const h=document.querySelector('.hero');if(h)h.style.setProperty('--scroll',window.scrollY+'px')},{passive:true});

      // Back to top
      const btt=document.getElementById('btt');
      if(btt){
        window.addEventListener('scroll',()=>{btt.classList.toggle('show',window.scrollY>800)},{passive:true});
        btt.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));
      }
    </script>
  </body>
</html>
