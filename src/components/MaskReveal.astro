---
interface Props {
  width?: string;
  height?: string;
}

const { width = "100%", height = "500px" } = Astro.props;
---

<div class="mask-reveal-wrapper" style={{ width, height }}>
  <canvas id="mask-canvas"></canvas>
</div>

<script is:inline>
  (async function initMask() {
    const canvas = document.getElementById("mask-canvas");
    if (!canvas) return;

    const THREE = await import("https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js");

    const wrapper = canvas.parentElement;
    const w = wrapper.clientWidth;
    const h = wrapper.clientHeight;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x121212);

    const camera = new THREE.PerspectiveCamera(45, w / h, 0.1, 100);
    camera.position.set(0, 0, 5);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Lights
    const ambientLight = new THREE.AmbientLight(0x404060, 0.5);
    scene.add(ambientLight);
    const mainLight = new THREE.DirectionalLight(0xffeedd, 2);
    mainLight.position.set(2, 3, 4);
    scene.add(mainLight);
    const fillLight = new THREE.DirectionalLight(0x4466ff, 0.8);
    fillLight.position.set(-2, 1, 3);
    scene.add(fillLight);
    const backLight = new THREE.DirectionalLight(0x6644ff, 0.5);
    backLight.position.set(0, -1, -3);
    scene.add(backLight);

    // --- Build mask ---
    const maskGroup = new THREE.Group();

    // Face base
    const faceGeo = new THREE.SphereGeometry(1.2, 32, 32);
    faceGeo.scale(1, 1.1, 0.5);
    const faceMat = new THREE.MeshPhysicalMaterial({
      color: 0x2a1a3a,
      metalness: 0.3,
      roughness: 0.4,
      clearcoat: 0.3,
      transparent: true,
      opacity: 0.92,
      side: THREE.DoubleSide,
    });
    maskGroup.add(new THREE.Mesh(faceGeo, faceMat));

    // Eye holes
    const eyeMat = new THREE.MeshPhysicalMaterial({
      color: 0x000000,
      roughness: 0.1,
      emissive: 0x220044,
      emissiveIntensity: 0.1,
    });
    const eyeGeo = new THREE.SphereGeometry(0.25, 16, 16);
    const leftEye = new THREE.Mesh(eyeGeo, eyeMat);
    leftEye.position.set(-0.4, 0.2, 0.7);
    leftEye.scale.set(1, 0.7, 0.3);
    maskGroup.add(leftEye);
    const rightEye = new THREE.Mesh(eyeGeo, eyeMat);
    rightEye.position.set(0.4, 0.2, 0.7);
    rightEye.scale.set(1, 0.7, 0.3);
    maskGroup.add(rightEye);

    // Mouth
    const mouth = new THREE.Mesh(
      new THREE.CylinderGeometry(0.02, 0.02, 0.5, 8),
      new THREE.MeshPhysicalMaterial({ color: 0x000000, roughness: 0.3 })
    );
    mouth.position.set(0, -0.35, 0.7);
    mouth.rotation.x = 0.1;
    maskGroup.add(mouth);

    // Crack lines
    const crackMat = new THREE.MeshPhysicalMaterial({
      color: 0xaa88ff,
      emissive: 0x4422aa,
      emissiveIntensity: 0.2,
      transparent: true,
      opacity: 0.6,
    });
    const cracks = [];
    const crackPositions = [
      [0.1, 0.3, 0.71, 0.4, 0.3],
      [-0.2, -0.1, 0.71, -0.6, 0.25],
      [0.3, -0.2, 0.71, 0.8, 0.2],
      [-0.1, 0.4, 0.71, 1.2, 0.15],
      [0.0, -0.1, 0.71, -0.3, 0.35],
      [0.15, -0.4, 0.71, 0.2, 0.18],
      [-0.25, 0.0, 0.71, -1.0, 0.22],
    ];
    crackPositions.forEach(([x, y, z, rot, len]) => {
      const geo = new THREE.CylinderGeometry(0.008, 0.015, len, 4);
      const mesh = new THREE.Mesh(geo, crackMat);
      mesh.position.set(x, y, z);
      mesh.rotation.z = rot;
      mesh.rotation.x = Math.random() * 0.3;
      maskGroup.add(mesh);
      cracks.push(mesh);
    });

    // Core glow
    const coreMat = new THREE.MeshPhysicalMaterial({
      color: 0xffffff,
      emissive: 0x8866ff,
      emissiveIntensity: 0,
      transparent: true,
      opacity: 0,
      roughness: 0.1,
      metalness: 0.0,
    });
    const core = new THREE.Mesh(new THREE.SphereGeometry(0.3, 20, 20), coreMat);
    core.position.set(0, 0, 0.3);
    maskGroup.add(core);

    // Particles
    const pCount = 300;
    const positions = new Float32Array(pCount * 3);
    for (let i = 0; i < pCount; i++) {
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const r = 1.3 + Math.random() * 0.8;
      positions[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      positions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta) * 1.1;
      positions[i * 3 + 2] = r * Math.cos(phi) * 0.5;
    }
    const particleMat = new THREE.PointsMaterial({
      color: 0x8866ff,
      size: 0.03,
      transparent: true,
      opacity: 0.4,
      blending: THREE.AdditiveBlending,
    });
    const particleGeo = new THREE.BufferGeometry();
    particleGeo.setAttribute("position", new THREE.BufferAttribute(positions, 3));
    const particles = new THREE.Points(particleGeo, particleMat);
    maskGroup.add(particles);

    scene.add(maskGroup);

    // Shatter pieces
    const pieces = [];
    for (let i = 0; i < 40; i++) {
      const geo = new THREE.CylinderGeometry(
        0.05 + Math.random() * 0.15, 0.05 + Math.random() * 0.15, 0.02, 3 + Math.floor(Math.random() * 4)
      );
      const mesh = new THREE.Mesh(geo, new THREE.MeshPhysicalMaterial({
        color: 0x2a1a3a, metalness: 0.3, roughness: 0.5,
        transparent: true, opacity: 0.9, side: THREE.DoubleSide,
      }));
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const r = 0.2 + Math.random() * 0.8;
      mesh.position.set(
        r * Math.sin(phi) * Math.cos(theta),
        r * Math.sin(phi) * Math.sin(theta) * 1.1,
        r * Math.cos(phi) * 0.5
      );
      mesh.userData = {
        velocity: new THREE.Vector3((Math.random() - 0.5) * 0.05, (Math.random() - 0.5) * 0.05, (Math.random() - 0.5) * 0.05),
        rotSpeed: new THREE.Vector3((Math.random() - 0.5) * 0.03, (Math.random() - 0.5) * 0.03, (Math.random() - 0.5) * 0.03),
        life: 1,
      };
      mesh.visible = false;
      maskGroup.add(mesh);
      pieces.push(mesh);
    }

    // Interaction
    let isRevealed = false;
    let revealProgress = 0;
    let isHovering = false;
    const raycaster = new THREE.Raycaster();
    const pointer = new THREE.Vector2();

    function checkHit(clientX, clientY) {
      const rect = canvas.getBoundingClientRect();
      pointer.x = ((clientX - rect.left) / rect.width) * 2 - 1;
      pointer.y = -((clientY - rect.top) / rect.height) * 2 + 1;
      raycaster.setFromCamera(pointer, camera);
      return raycaster.intersectObject(maskGroup, true).length > 0;
    }

    canvas.addEventListener("pointerdown", (e) => {
      if (!isRevealed && checkHit(e.clientX, e.clientY)) {
        isRevealed = true;
        clearTimeout(autoTrigger);
      }
    });
    canvas.addEventListener("pointermove", (e) => {
      if (isRevealed) return;
      isHovering = checkHit(e.clientX, e.clientY);
      canvas.style.cursor = isHovering ? "pointer" : "default";
    });

    const autoTrigger = setTimeout(() => { if (!isRevealed) isRevealed = true; }, 5000);

    // Animation loop
    function animate() {
      requestAnimationFrame(animate);

      maskGroup.rotation.y += 0.005;
      maskGroup.rotation.x = Math.sin(Date.now() * 0.0003) * 0.05;

      if (isHovering && !isRevealed) {
        const pulse = Math.sin(Date.now() * 0.008) * 0.2 + 0.6;
        crackMat.opacity = pulse;
        crackMat.emissiveIntensity = 0.2 + Math.sin(Date.now() * 0.006) * 0.15;
        coreMat.emissiveIntensity = 0.2 + Math.sin(Date.now() * 0.006) * 0.15;
        coreMat.opacity = 0.2 + Math.sin(Date.now() * 0.006) * 0.15;
      }

      if (isRevealed && revealProgress < 1) {
        revealProgress = Math.min(revealProgress + 0.015, 1);
        faceMat.opacity = 0.92 * (1 - revealProgress);
        coreMat.emissiveIntensity = revealProgress * 2;
        coreMat.opacity = revealProgress;
        crackMat.opacity = 0.6 * (1 - revealProgress) + revealProgress * 0.8;
        crackMat.emissiveIntensity = revealProgress * 1.5;
        particleMat.opacity = 0.4 + revealProgress * 0.6;
        particleMat.color.setHSL(0.75 - revealProgress * 0.15, 1, 0.5 + revealProgress * 0.3);
        particleMat.size = 0.03 + revealProgress * 0.06;
        const s = 1 + revealProgress * 0.5;
        core.scale.set(s, s, s);

        if (revealProgress > 0.3) {
          pieces.forEach(p => {
            p.visible = true;
            p.position.add(p.userData.velocity);
            p.rotation.x += p.userData.rotSpeed.x;
            p.rotation.y += p.userData.rotSpeed.y;
            p.rotation.z += p.userData.rotSpeed.z;
            p.userData.velocity.multiplyScalar(0.99);
            p.userData.life -= 0.005;
            p.material.opacity = Math.max(0, p.userData.life);
          });
        }
      }

      renderer.render(scene, camera);
    }
    animate();

    // Resize
    function onResize() {
      const w2 = wrapper.clientWidth;
      const h2 = wrapper.clientHeight;
      camera.aspect = w2 / h2;
      camera.updateProjectionMatrix();
      renderer.setSize(w2, h2);
    }
    window.addEventListener("resize", onResize);
  })();
</script>

<style is:global>
  .mask-reveal-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    margin: 2rem 0;
  }
  .mask-reveal-wrapper canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
