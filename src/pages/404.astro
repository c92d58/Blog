---
import Layout from "../components/Layout.astro";
---

<Layout title="404 — WAHSUN ｜ Blog">
  <section class="container" style="text-align:center;padding:6rem 0 4rem">
    <p style="font-family:var(--font-mono);font-size:.68rem;color:var(--text3);margin-bottom:1rem;text-transform:uppercase;letter-spacing:.08em">
      $ curl -s blog.wahsun.org{ Astro.url.pathname }
    </p>
    <p style="font-family:var(--font-mono);font-size:5rem;font-weight:800;color:var(--g);margin-bottom:.75rem;line-height:1">404</p>
    <p style="font-family:var(--font-mono);font-size:.9rem;color:var(--text);margin-bottom:.25rem">PAGE_NOT_FOUND</p>
    <p style="font-size:.85rem;color:var(--text2);margin-bottom:2rem">此頁面不存在，或已被移動到別處。</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a href="/" style="font-family:var(--font-mono);font-size:.72rem;color:var(--bg);background:var(--g);padding:.5rem 1.2rem;border-radius:2px;text-decoration:none;font-weight:600;text-transform:uppercase;letter-spacing:.04em;transition:opacity .2s">← 回到首頁</a>
      <a href="/search" style="font-family:var(--font-mono);font-size:.72rem;color:var(--text2);padding:.5rem 1.2rem;border:1px solid var(--border);border-radius:2px;text-decoration:none;transition:all .2s">搜尋文章</a>
    </div>
  </section>
</Layout>
