---
import Layout from "../components/Layout.astro";
---

<Layout title="404 — 找不到頁面">
  <section style="text-align:center;padding:4rem 0">
    <p style="font-family:var(--f-display);font-size:4rem;color:var(--accent);margin-bottom:.75rem">404</p>
    <p style="font-size:1.125rem;color:var(--t2);margin-bottom:1.5rem">此頁面不存在。</p>
    <a href="/" style="font-family:var(--f-mono);font-size:.8125rem;color:var(--t2);padding:.5rem 1rem;border:1px solid var(--bdr);border-radius:var(--r-xs);transition:all .15s">← 回到首頁</a>
  </section>
</Layout>
