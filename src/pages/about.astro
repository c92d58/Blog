---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
---

<Layout title="關於 — 部落格" description="關於這個部落格。">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "關於這個部落格",
    "description": "關於這個部落格。",
    "url": new URL("/about", Astro.site).href,
    "isPartOf": {
      "@type": "WebSite",
      "name": "部落格",
      "url": Astro.site?.href,
    },
  })} />
  <section class="about">
    <Heading as="h1">關於</Heading>
    <Prose>
      <p>
        WAHSUN 的數位庭園，專注於自架基礎設施、AI 代理開發與 DevOps 實踐。
      </p>
      <p>
        你會在裡找到關於自架伺服器、AI 代理、DevOps 實務的文章，
        偶爾也有一些生活與哲學的反思。內容由好奇心驅動，
        偏好動手打造勝過掏錢購買。
      </p>
      <p>
        沒有電子報。沒有彈窗。沒有追蹤。只有文字。
      </p>
      <p>
        信箱：<a href="mailto:x@wahsun.org">x@wahsun.org</a>
      </p>
    </Prose>
  </section>
</Layout>

<style>
  .about {
    max-width: var(--width-content);
  }
</style>
