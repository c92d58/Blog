---
import Layout from "../components/Layout.astro";
import { getPublishedPosts } from "../lib/posts";

const allPosts = await getPublishedPosts();

// Group posts by year
const yearGroups = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = post.data.date.getFullYear();
  if (!yearGroups.has(year)) yearGroups.set(year, []);
  yearGroups.get(year)!.push(post);
}
const sortedYears = [...yearGroups.keys()].sort((a, b) => b - a);
const totalArticles = allPosts.length;
---

<Layout title="歸檔 — WAHSUNの自留地" description={`共 ${totalArticles} 篇文章，按時間排列。`}>
  <section class="archive-page">

    <header class="page-hero">
      <h1 class="page-hero-title animate-fade-up delay-1">
        <span class="hero-gradient">歸檔</span>
      </h1>
      <p class="page-hero-meta animate-fade-up delay-2">
        共 <strong>{totalArticles}</strong> 篇文章，按年份排列
      </p>
    </header>

    <div class="archive-list">
      {sortedYears.map((year, yi) => (
        <div class="year-group animate-fade-up delay-{Math.min(yi + 1, 6)}">
          <div class="section-label-wrap">
            <span class="section-label">{year}</span>
            <span class="year-count">{yearGroups.get(year)!.length} 篇</span>
          </div>

          <ul class="post-list">
            {yearGroups.get(year)!.map((post, i) => {
              const formattedDate = post.data.date.toLocaleDateString("en-US", {
                month: "long",
                day: "numeric",
              });
              return (
                <li class="post-item ink-border">
                  <a href={`/posts/${post.id}`}>
                    <span class="post-meta">
                      <span class="post-number">#{(allPosts.indexOf(post) + 1).toString().padStart(2, '0')}</span>
                      <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                    </span>
                    <span class="post-title">{post.data.title}</span>
                    <span class="post-description">{post.data.description}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    {totalArticles === 0 && (
      <p class="archive-empty">暫無文章</p>
    )}
  </section>
</Layout>

<style>
  .archive-page { padding: 1rem 0 4rem; }

  /* ─── Hero ──────────────────────────────── */
  .page-hero {
    text-align: center;
    padding: 2rem 0 2.5rem;
  }
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .hero-gradient {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% auto;
    animation: shimmer 4s ease infinite;
  }
  .page-hero-meta {
    font-size: 1rem;
    color: var(--text-secondary);
    font-style: italic;
  }
  .page-hero-meta strong {
    font-style: normal;
    font-weight: 600;
  }

  /* ─── Year Group ────────────────────────── */
  .year-group {
    margin-bottom: 2rem;
  }
  .section-label-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .year-count {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  /* ─── Post List ──────────────────────────── */
  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-item {
    padding: 1.25rem;
    background: var(--surface);
    box-shadow: var(--shadow-card);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .post-item:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-card-glow);
    transform: translateY(-3px);
  }
  .post-item a {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-decoration: none;
    color: var(--text);
  }
  .post-item time {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .post-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .post-item a:hover .post-title {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .post-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── Empty state ───────────────────────── */
  .archive-empty {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-tertiary);
    font-style: italic;
  }

  /* ─── Responsive ────────────────────────── */
  @media (max-width: 600px) {
    .page-hero-title { font-size: 1.75rem; }
    .page-hero { padding: 1.5rem 0; }
    .post-item { padding: 1rem; }
    .year-group { margin-bottom: 1.5rem; }
  }
</style>
