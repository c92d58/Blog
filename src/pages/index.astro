---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import { getPublishedPosts } from "../lib/posts";

const PAGE_SIZE = 10;

const allPosts = await getPublishedPosts();

const posts = allPosts.slice(0, PAGE_SIZE);
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
---

<Layout title="部落格">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://blog.wahsun.org",
    "@type": "WebSite",
    "name": "部落格",
    "description": "一方靜謐閱讀之地。",
    "url": Astro.site?.href,
  })} />
  <section class="max-w-[var(--width-content)]">
    <header class="mb-[var(--spacing-2xl)]">
      <Heading as="h1"> </Heading>
      <p class="text-[var(--color-text-secondary)] mt-[var(--spacing-sm)]">
        一方靜謐閱讀之地，書寫系統、科技，以及我們周遭的世界。
      </p>
    </header>
    <ul class="list-none p-0">
      {
        posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <li class="
              group border-b border-[var(--color-border)]
              first:border-t first:border-[var(--color-border)]
              transition-colors duration-200
              hover:bg-[var(--color-surface)]
            ">
              <a href={`/posts/${post.id}`} class="
                no-underline text-inherit
                grid grid-cols-1 gap-y-1.5
                px-[var(--spacing-lg)] py-[var(--spacing-lg)]
                max-md:px-[var(--spacing-md)]
              ">
                <!-- Title with subtle underline on hover -->
                <span class="
                  font-heading text-lg/6 font-semibold tracking-tight
                  text-[var(--color-text)]
                  [text-decoration:none]
                  transition-colors duration-150
                  group-hover:text-[var(--color-text-secondary)]
                ">{post.data.title}</span>
                <span class="
                  font-body text-sm/6
                  text-[var(--color-text-secondary)]
                ">{post.data.description}</span>
                <!-- Meta row: date + reading time + tags -->
                <div class="flex flex-wrap items-center gap-2 mt-1">
                  <time datetime={post.data.date.toISOString()} class="
                    font-heading text-xs
                    text-[var(--color-text-tertiary)]
                  ">{formattedDate}</time>
                  {post.data.readingTime && (
                    <span class="
                      font-heading text-xs
                      text-[var(--color-text-tertiary)]
                    ">· {post.data.readingTime} 分鐘</span>
                  )}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 ml-2">
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class="
                          font-heading text-[0.65rem] leading-none
                          text-[var(--color-text-tertiary)]
                          border border-[var(--color-border)]
                          rounded-sm px-1.5 py-0.5
                        ">{tag}</span>
                      ))}
                      {post.data.tags.length > 2 && (
                        <span class="
                          font-heading text-[0.6rem] leading-none
                          text-[var(--color-text-tertiary)]
                        ">+{post.data.tags.length - 2}</span>
                      )}
                    </div>
                  )}
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
    {totalPages > 1 && (
      <nav class="flex justify-between items-center mt-[var(--spacing-xl)] pt-[var(--spacing-lg)]" aria-label="Pagination">
        <span class="font-heading text-xs text-[var(--color-text-tertiary)]">
          第 1 頁，共 {totalPages} 頁
        </span>
        <a href="/page/2" class="
          font-heading text-sm no-underline
          text-[var(--color-text-secondary)]
          hover:text-[var(--color-text)]
          transition-colors duration-150
        ">較舊文章 &rarr;</a>
      </nav>
    )}
  </section>
</Layout>
