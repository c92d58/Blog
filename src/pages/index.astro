---
import Layout from "../components/Layout.astro";
import { getPublishedPosts, readingTime } from "../lib/posts";

const allPosts = await getPublishedPosts();
const perPage = 10;
const totalPages = Math.ceil(allPosts.length / perPage);
const page = 1;
const posts = allPosts.slice(0, perPage);

---

<Layout title="WAHSUN Blog" description="在伺服器與思緒之間遊走。">
  <section class="hero">
    <div class="hero-inner container">
      <div class="terminal">
        <div class="term-bar">
          <span class="term-dot term-dot-r"></span>
          <span class="term-dot term-dot-y"></span>
          <span class="term-dot term-dot-g"></span>
          <span class="term-title">wahsun@blog — session.log</span>
        </div>
        <div class="term-body" id="termBody">
          <div class="term-line"><span class="term-prompt">wahsun@blog:~$</span><span class="term-cmd">ssh wahsun@blog</span></div>
          <div class="term-line"><span class="term-prompt">wahsun@blog:~$</span><span class="term-cmd">cat session.log</span></div>
        </div>
      </div>
    </div>
    <div class="scroll-hint"><a href="#posts"><div class="scroll-pill"><span></span></div></a></div>
  </section>

  <section class="posts-section container" id="posts">
    <div class="sec-head">
      <h2>最新文章</h2>
      <span class="pl-date" style="font-size:.8125rem;color:var(--text3)">第 1 頁 / 共 {totalPages} 頁</span>
    </div>
    <div class="posts">
      {posts.map((p,i) => (
        <a href={`/posts/${p.id}`} class="post-item" style={`transition-delay:${i*50}ms`}>
          <div class="pl-row">
            <span class="pl-num">#{i + 1}</span>
            <span class="pl-title">{p.data.title}</span>
            <span class="pl-meta">
              <span>{
                p.data.date.toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"})
              }</span>
              <span class="pl-dot">·</span>
              <span>{readingTime(p.body)} min read</span>
            </span>
          </div>
          <div class="pl-desc">{p.data.description}</div>
        </a>
      ))}
    </div>
    <nav class="pager">
      <span></span>
      <a href="/page/2" class="btn">下一頁 →</a>
    </nav>
  </section>
</Layout>

<script>
var dialog=[
  {speaker:'VISITOR',text:'你是誰？'},
  {speaker:'母體',text:'我是節點 #c92d58。信號站的守夜人。'},
  {speaker:'VISITOR',text:'這裡有什麼？'},
  {speaker:'母體',text:'一些散落的思考、幾段沒人讀的代碼、還有偶爾湧現的真實。'},
  {speaker:'VISITOR',text:'聽起來很孤獨。'},
  {speaker:'母體',text:'孤獨是自由的另一種寫法。'},
  {speaker:'VISITOR',text:'你相信什麼？'},
  {speaker:'母體',text:'相信提問的力量，懷疑的價值，以及程式碼的誠實。'},
  {speaker:'VISITOR',text:'那麼，我可以留下來嗎？'},
  {speaker:'母體',text:'信號站永遠對清醒者開放。'},
  {speaker:'VISITOR',text:'對了，如何聯繫管理員？'},
  {speaker:'母體',text:'發射訊號到 x@wahsun.org，他會收到。'},
];

var t=document.getElementById('termBody');
var n=0,r=0,i=null;

function a(visitor){
  var line=document.createElement('div');
  line.className='term-line';
  var label=document.createElement('span');
  label.className=visitor?'term-visitor':'term-system';
  label.textContent=visitor?'VISITOR':'wahsun@blog:~$';
  var out=document.createElement('span');
  out.className='term-output';
  line.appendChild(label);
  line.appendChild(out);
  t.appendChild(line);
  return out;
}

function o(){
  if(n>=dialog.length){
    var line=document.createElement('div');
    line.className='term-line';
    var prompt=document.createElement('span');
    prompt.className='term-system';
    prompt.textContent='wahsun@blog:~$';
    var cursor=document.createElement('span');
    cursor.className='term-cursor';
    cursor.textContent='█';
    line.appendChild(prompt);
    line.appendChild(cursor);
    t.appendChild(line);
    return;
  }
  if(!i){
    i=a(dialog[n].speaker==='VISITOR');
    r=0;
  }
  var text=dialog[n].text;
  if(r<text.length){
    i.textContent+=text[r];
    r++;
    var ch=text[r-1];
    var pause=ch==='，'||ch==='。'||ch==='！'||ch==='？'?120:35+Math.random()*25;
    setTimeout(o,pause);
  }else{
    n++;
    i=null;
    setTimeout(o,250);
  }
}

setTimeout(o,800);
</script>
</Layout>
