---
import Layout from "../components/Layout.astro";
import { getPublishedPosts, readingTime } from "../lib/posts";

const allPosts = await getPublishedPosts();
const perPage = 10;
const totalPages = Math.ceil(allPosts.length / perPage);
const page = 1;
const posts = allPosts.slice(0, perPage);

---

<Layout title="WAHSUN ｜ Blog" description="在伺服器與思緒之間遊走。">
  <section class="hero">
    <div class="hero-inner container">
      <p class="label"><span class="d"></span> Dispatches · {allPosts.length} posts</p>
      <h1>記錄思考的痕跡</h1>
      <p class="bio">這裡沒有聳動的標題，也沒有急著說服的論點。只是一個人在深夜寫下來的東西——關於系統、關於認知、關於那些反覆出現卻始終沒有答案的問題。</p>
      <div class="actions">
        <a href="#posts" class="btn btn-p">閱讀文章</a>
        <a href="mailto:x@wahsun.org" class="btn">聯絡我</a>
      </div>
    </div>
    <div class="scroll-hint"><span></span></div>
  </section>

  <section class="posts-section container" id="posts">
    <div class="sec-head">
      <h2>最新文章</h2>
      <span class="pl-date" style="font-size:.8125rem;color:var(--fg3)">第 1 頁 / 共 {totalPages} 頁</span>
    </div>
    <div class="posts">
      {posts.map((p,i) => (
        <a href={`/posts/${p.id}`} class="post-item" style={`transition-delay:${i*50}ms`}>
          <div>
            <div class="pl-meta">#{i + 1}</div>
            <div class="pl-title">{p.data.title}</div>
            <div class="pl-desc">{p.data.description?.slice(0,80)}...</div>
          </div>
          <div class="pl-date">{p.data.date.toLocaleDateString("zh-TW",{year:"numeric",month:"short",day:"numeric"})}</div>
        </a>
      ))}
    </div>
    <nav class="pager">
      <span></span>
      <a href="/page/2" class="btn">下一頁 →</a>
    </nav>
  </section>
</Layout>
</Layout>
