---
import Layout from "../components/Layout.astro";
import { getPublishedPosts, readingTime } from "../lib/posts";

const allPosts = await getPublishedPosts();
const perPage = 10;
const totalPages = Math.ceil(allPosts.length / perPage);
const page = 1;
const posts = allPosts.slice(0, perPage);

---

<Layout title="WAHSUN Blog" description="在伺服器與思緒之間遊走。">
  <section class="hero">
    <div class="hero-inner container">
      <!-- 駭客帝國終端對話 -->
      <div class="crt" id="crt">
        <div class="crt-scanline"></div>
        <div class="term-win">
          <div class="term-bar">
            <span class="t-dot t-dot-r"></span>
            <span class="t-dot t-dot-y"></span>
            <span class="t-dot t-dot-g"></span>
            <span class="t-title">matrix@wahsun:~/session</span>
          </div>
          <div class="term-body" id="termBody"></div>
          <div class="term-cursor-line" id="cursorLine">
            <span class="t-prompt">matrix@wahsun:~$</span>
            <span class="t-cursor" id="tcursor">█</span>
          </div>
        </div>
      </div>
      <div class="actions">
        <a href="#posts" class="btn">閱讀文章 →</a>
      </div>
    </div>
    <div class="scroll-hint"><a href="#posts"><div class="scroll-pill"><span></span></div></a></div>
  </section>

  <section class="posts-section container" id="posts">
    <div class="sec-head">
      <h2>最新文章</h2>
      <span class="pl-date" style="font-size:.8125rem;color:var(--text3)">第 1 頁 / 共 {totalPages} 頁</span>
    </div>
    <div class="posts">
      {posts.map((p,i) => (
        <a href={`/posts/${p.id}`} class="post-item" style={`transition-delay:${i*50}ms`}>
          <div class="pl-row">
            <span class="pl-num">#{i + 1}</span>
            <span class="pl-title">{p.data.title}</span>
            <span class="pl-meta">
              <span>{
                p.data.date.toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"})
              }</span>
              <span class="pl-dot">·</span>
              <span>{readingTime(p.body)} min read</span>
            </span>
          </div>
          <div class="pl-desc">{p.data.description}</div>
        </a>
      ))}
    </div>
    <nav class="pager">
      <span></span>
      <a href="/page/2" class="btn">下一頁 →</a>
    </nav>
  </section>
</Layout>

<script>
// 駭客帝國終端對話腳本
const dialog = [
  { type: 'system', text: '[SYSTEM] 檢測到未知訪客。掃描中……' },
  { type: 'visitor', text: './connect --query="這是什麼地方"' },
  { type: 'system', text: '[SYSTEM] 查詢結果：wahsun.org 節點。' },
  { type: 'system', text: '          一個人的筆記節點。伺服器低鳴，螢幕亮著這些年寫下的東西。' },
  { type: 'system', text: '          無演算法干預，無KPI追蹤，純文字信號。' },
  { type: 'visitor', text: './whoami' },
  { type: 'system', text: '[SYSTEM] 身份：WAHSUN' },
  { type: 'system', text: '          對世界充滿好奇心的人。在伺服器與思緒之間遊走。' },
  { type: 'system', text: '          維護安靜運行的服務，寫個人使用的程式碼，讀讓自己清醒的書。' },
  { type: 'visitor', text: './contact' },
  { type: 'system', text: '[SYSTEM] 通道：x@wahsun.org' },
  { type: 'system', text: '          信號已送達。期待你的傳輸。' },
];

const body = document.getElementById('termBody');
const cursorLine = document.getElementById('cursorLine');
const cursor = document.getElementById('tcursor');
let step = 0;
let charPos = 0;
let typing = false;

function runStep() {
  if (step >= dialog.length) {
    cursorLine.style.display = 'flex';
    cursor.style.animation = 'blink 0.6s step-end infinite';
    return;
  }
  const s = dialog[step];
  const line = document.createElement('div');
  line.className = 't-line';

  if (s.type === 'system') {
    line.innerHTML = '<span class="t-out">' + s.text + '</span>';
  } else {
    line.innerHTML = '<span class="t-prompt">matrix@wahsun:~$</span> <span class="t-cmd"></span>';
  }
  body.appendChild(line);
  line.scrollIntoView({ behavior: 'smooth', block: 'end' });

  const textEl = s.type === 'system'
    ? line.querySelector('.t-out')
    : line.querySelector('.t-cmd');

  charPos = 0;
  typing = true;
  typeText(s.text, textEl);
}

function typeText(text, el) {
  if (charPos < text.length) {
    el.textContent += text[charPos];
    charPos++;
    const ch = text[charPos - 1];
    const pause = ch === '，' || ch === '。' || ch === '！' || ch === '？' ? 120 : 30 + Math.random() * 25;
    setTimeout(() => typeText(text, el), pause);
  } else {
    typing = false;
    step++;
    const pause = step >= dialog.length ? 500 : 600;
    setTimeout(runStep, pause);
  }
}

cursorLine.style.display = 'none';
setTimeout(runStep, 400);
</script>
</Layout>
