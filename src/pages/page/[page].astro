---
import Layout from "../../components/Layout.astro";
import { getPublishedPosts, readingTime } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const pp = 10, tp = Math.ceil(posts.length / pp);
  return Array.from({length: tp - 1}, (_, i) => ({
    params: { page: String(i + 2) },
    props: { posts: posts.slice((i + 1) * pp, (i + 2) * pp), page: i + 2, totalPages: tp }
  }));
}

const { posts, page, totalPages } = Astro.props;
---

<Layout title={`第 ${page} 頁 — WAHSUN ｜ Blog`}>
  <section class="posts-section container" style="padding-top:6rem">
    <div class="sec-head">
      <h2>文章列表</h2>
      <span style="font-size:.8125rem;color:var(--fg3)">第 {page} 頁 / 共 {totalPages} 頁</span>
    </div>
    <div class="posts">
      {posts.map((p, i) => (
        <a href={`/posts/${p.id}`} class="post-item" style={`transition-delay:${i*50}ms`}>
          <div>
            <div class="pl-meta">#{(page - 1) * 10 + i + 1}</div>
            <div class="pl-title">{p.data.title}</div>
            <div class="pl-desc">{p.data.description?.slice(0,80)}...</div>
          </div>
          <div class="pl-date">{p.data.date.toLocaleDateString("zh-TW",{year:"numeric",month:"short",day:"numeric"})}</div>
        </a>
      ))}
    </div>
    <nav class="pager">
      {page > 2 ? <a href={`/page/${page - 1}`} class="btn">← 上一頁</a> : <a href="/" class="btn">← 首頁</a>}
      {page < totalPages ? <a href={`/page/${page + 1}`} class="btn">下一頁 →</a> : <span></span>}
    </nav>
  </section>
</Layout>
