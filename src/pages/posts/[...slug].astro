---
import Layout from "../../components/Layout.astro";
import { render } from "astro:content";
import { getPublishedPosts, readingTime } from "../../lib/posts";

export async function getStaticPaths() {
  return (await getPublishedPosts()).map(p => ({params:{slug:p.id},props:{post:p}}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const all = await getPublishedPosts();
const idx = all.findIndex(p=>p.id===post.id);
const prev = idx > 0 ? all[idx-1] : null;
const next = idx < all.length-1 ? all[idx+1] : null;
---

<Layout title={`${post.data.title} — WAHSUN ｜ Blog`} description={post.data.description}>
  <article class="article">
    <a href="/" class="art-back">← 返回首頁</a>
    <h1 class="art-title">{post.data.title}</h1>
    <div class="art-meta">
      <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"})}</time>
      <span>·</span><span>{readingTime(post.body)} min read</span>
      {(post.data.tags||[]).slice(0,4).map(t => <span class="atag">{t}</span>)}
    </div>
    <div class="prose"><Content /></div>
    <nav class="pnav">
      {prev ? <a href={`/posts/${prev.id}`}><div class="pnl">← Previous</div><div class="pnt">{prev.data.title}</div></a> : <div></div>}
      {next ? <a href={`/posts/${next.id}`} style="text-align:right"><div class="pnl">Next →</div><div class="pnt">{next.data.title}</div></a> : <div></div>}
    </nav>
  </article>
</Layout>
